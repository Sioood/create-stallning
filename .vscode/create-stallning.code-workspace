{
  "folders": [
    {
      "name": "/",
      "path": "../",
    },
    {
      "name": "config",
      "path": "../packages/config",
    },
  ],
  "settings": {
    "files.exclude": {
      "**/.git": true,
      "**/.svn": true,
      "**/.hg": true,
      "**/CVS": true,
      "**/.DS_Store": true,
      "**/Thumbs.db": true,
      "node_modules": true,
      "apps/": true,
      "packages/": true,
    },
    "conventionalCommits.scopes": ["global", "config", "docs"],
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "[javascript]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[typescript]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[typescriptreact]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[javascriptreact]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[json]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[jsonc]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[markdown]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "[yaml]": {
      "editor.defaultFormatter": "oxc.oxc-vscode",
    },
    "oxc.enable": true,
    "oxc.enable.oxfmt": true,
    "cSpell.words": ["stallning", "oxlint"],
  },
  "extensions": {
    "recommendations": [
      "oxc.oxc-vscode",
      "dbaeumer.vscode-eslint",
      "vivaxy.vscode-conventional-commits",
      "gruntfuggly.todo-tree",
      "antfu.iconify",
      "yoavbls.pretty-ts-errors",
    ],
  },
}
