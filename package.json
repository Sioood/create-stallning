{
  "name": "create-stallning",
  "version": "0.1.0",
  "description": "CLI to create a new project with stallning monorepo boilerplate",
  "homepage": "https://github.com/sioood/create-stallning#readme",
  "bugs": {
    "url": "https://github.com/sioood/create-stallning/issues"
  },
  "license": "MIT",
  "author": "Sioood <contact@theodupont.fr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sioood/create-stallning.git"
  },
  "bin": {
    "create-stallning": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test:run",
    "knip": "knip",
    "changeset": "changeset",
    "changeset:gen": "node .changeset/changeset-conventional-commits.ts",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "tiged": "^2.12.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@changesets/read": "^0.6.5",
    "@changesets/types": "^6.1.0",
    "@changesets/write": "^0.4.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@manypkg/get-packages": "^3.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "knip": "^5.65.0",
    "lint-staged": "^16.2.6",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,mjs,cjs,json,md,yml,yaml}": [
      "oxfmt --write"
    ],
    "*.{ts,tsx,mts,cts,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        100
      ],
      "scope-enum": [
        2,
        "always",
        [
          "global",
          "config",
          "release"
        ]
      ],
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  },
  "engines": {
    "node": ">=25.8.0"
  }
}
